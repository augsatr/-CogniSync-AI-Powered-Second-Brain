# CogniSync Environment Configuration
# Copy this file to .env and fill in your values

# --- Authentication ---
SECRET_KEY=your-secret-key-at-least-32-chars
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cognisync
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/cognisync

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Optional: OpenAI (for enhanced AI features) ---
OPENAI_API_KEY=

# --- App Config ---
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
